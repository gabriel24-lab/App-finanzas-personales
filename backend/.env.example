# Puerto en el que corre la API
PORT=4000

# "development" o "production". En producción, la cookie de sesión se marca
# como Secure (solo se envía sobre HTTPS).
NODE_ENV=development

# Cadena de conexión a MongoDB.
# IMPORTANTE: las transacciones multi-documento (session.startTransaction)
# requieren que MongoDB corra como Replica Set (incluso uno de un solo nodo)
# o que uses MongoDB Atlas, que ya viene configurado como replica set.
# En producción, la URI debe apuntar a un usuario de MongoDB con
# autenticación (usuario/contraseña fuertes) y rol restringido a
# readWrite únicamente sobre la base de datos de esta app (no admin).
MONGO_URI=mongodb://localhost:27017/finanzas_app

# Secreto para firmar JWT. Usa un valor largo y aleatorio en producción,
# por ejemplo generado con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia_este_valor_por_un_secreto_seguro

# URL(s) exacta(s) del frontend permitidas por CORS, separadas por coma si
# hay más de una (ej: staging y producción). Debe ser el origen real del
# frontend desplegado, no "*", para que la cookie httpOnly de sesión pueda
# viajar con `credentials: true`.
CORS_ORIGIN=http://localhost:5173
